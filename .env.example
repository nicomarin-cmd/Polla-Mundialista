# ── Supabase ─────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── WalletConnect (gratis en cloud.walletconnect.com) ─────────────────────────
VITE_WALLETCONNECT_PROJECT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Chain (44787 = Celo Alfajores testnet, 42220 = Celo mainnet) ──────────────
VITE_CHAIN_ID=44787

# ── Wallet pública del operador (recibe los fondos en custodia) ───────────────
# Es la address PÚBLICA del operador — seguro ponerla en el frontend.
VITE_PLATFORM_WALLET=0x0000000000000000000000000000000000000000

# ── Supabase Edge Functions (NUNCA exponer en el frontend) ────────────────────
# Guardar en Supabase → Project Settings → Edge Functions → Secrets
#
# PLATFORM_OPERATOR_PRIVATE_KEY=0x...   # wallet del operador (necesita CELO para gas)
# PLATFORM_OPERATOR_ADDRESS=0x...       # address pública del operador
